# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# generated RDF / exports
/data/*.ttl
/data/*.jsonld
/data/exports/
# Calculation history snapshots are preserved on disk for safety,
# but should not be committed (they are append-only and can grow quickly).
/data/*-calc-history/
# Manual quantity overrides are local operator state.
/data/*-passport-quantity-overrides.json
# Uploaded project documents (invoices, site photos, scans) — local evidence store.
/data/*-documents/
#
# Keep local IFC/model inputs out of Git history.
/data/**/*.ifc
# Tiny bundled second sample for Phase 1 (~400 KB); large project IFCs stay untracked.
!/data/ifc-sample-small.ifc

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local env (secrets). `.env.example` is the committed template (no real values).
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# Large historical project archive (binaries, spreadsheets, exports)
docs/DataSetArch/**

# typescript
*.tsbuildinfo
next-env.d.ts
.aider*
