# Copy to `.env` or `.env.local` and fill in values. Do not commit real secrets.
# Next.js loads `.env`, `.env.local`, `.env.development.local`, etc. (see Next.js env docs).
# Plain Node scripts (e.g. `node scripts/clean-pipeline.js`) do not auto-load these files;
# either export vars in your shell or pass `PROJECT_ID=myproj` on the command line.

PROJECT_ID=example

# 2050 Materials — **developer token** from https://app.2050-materials.com/accounts/edit-account/
# App code should exchange it for an api_token via GET …/developer/api/getapitoken/ (see scripts/test-2050-api.mjs).
MATERIALS_2050_API_TOKEN=
